#!/bin/sh
# pentbox — démarre un bureau XFCE accessible via navigateur (noVNC).
# Lancé par l'entrypoint quand PENTBOX_DESKTOP=1. Pilote Xvnc DIRECTEMENT (sa
# CLI est stable entre distros, contrairement au wrapper vncserver qui diffère
# entre Debian et Arch). localhost only (bind 127.0.0.1), sans auth VNC : accès
# local mono-utilisateur. NE PAS exposer le port publiquement.
set -e

DISP="${PENTBOX_DESKTOP_DISPLAY:-1}"
NOVNC_PORT="${PENTBOX_DESKTOP_PORT:-6080}"
VNC_PORT=$((5900 + DISP))
GEOMETRY="${PENTBOX_DESKTOP_GEOMETRY:-1600x900}"
: "${HOME:=/home/pentbox}"

# Repartir propre si un display résiduel traîne.
rm -f "/tmp/.X${DISP}-lock" "/tmp/.X11-unix/X${DISP}" 2>/dev/null || true

# Serveur X virtuel + VNC : Xvnc en direct, localhost, sans auth.
Xvnc ":$DISP" -geometry "$GEOMETRY" -depth 24 -rfbport "$VNC_PORT" \
     -SecurityTypes None -localhost -AlwaysShared >/tmp/pentbox-xvnc.log 2>&1 &

# Attendre que le display soit prêt.
i=0
while [ ! -S "/tmp/.X11-unix/X${DISP}" ] && [ "$i" -lt 20 ]; do
    sleep 0.5
    i=$((i + 1))
done

# Session de bureau XFCE sur ce display.
export DISPLAY=":$DISP"
if command -v dbus-launch >/dev/null 2>&1; then
    dbus-launch --exit-with-session startxfce4 >/tmp/pentbox-xfce.log 2>&1 &
else
    startxfce4 >/tmp/pentbox-xfce.log 2>&1 &
fi

# Localiser les fichiers web noVNC (chemin différent selon la distro :
# Debian = /usr/share/novnc, Arch = /usr/share/webapps/novnc).
NOVNC_WEB=/usr/share/novnc
for d in /usr/share/novnc /usr/share/webapps/novnc; do
    [ -f "$d/vnc.html" ] && NOVNC_WEB="$d" && break
done

# noVNC (websockify) → VNC, en écoute sur localhost uniquement.
exec websockify --web "$NOVNC_WEB" "127.0.0.1:$NOVNC_PORT" "localhost:$VNC_PORT"
