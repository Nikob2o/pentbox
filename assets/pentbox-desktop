#!/bin/sh
# pentbox — démarre un bureau XFCE accessible via navigateur (noVNC).
# Lancé par l'entrypoint quand PENTBOX_DESKTOP=1. Pilote Xvnc DIRECTEMENT (sa
# CLI est stable entre distros, contrairement au wrapper vncserver qui diffère
# entre Debian et Arch). localhost only (bind 127.0.0.1). Auth VNC par mot de
# passe si PENTBOX_VNC_PASSWORD est posé (le navigateur le demandera), sinon
# sans auth. NE PAS exposer le port publiquement.
set -e

DISP="${PENTBOX_DESKTOP_DISPLAY:-1}"
NOVNC_PORT="${PENTBOX_DESKTOP_PORT:-6080}"
VNC_PORT=$((5900 + DISP))
GEOMETRY="${PENTBOX_DESKTOP_GEOMETRY:-1600x900}"
: "${HOME:=/home/pentbox}"

# Repartir propre si un display résiduel traîne.
rm -f "/tmp/.X${DISP}-lock" "/tmp/.X11-unix/X${DISP}" 2>/dev/null || true

# Authentification VNC : mot de passe (VncAuth) si PENTBOX_VNC_PASSWORD est posé,
# sinon aucune. Génère le fichier passwd VNC standard avec l'outil dispo :
# `vncpasswd -f` (TigerVNC, présent sur BlackArch) ou `x11vnc -storepasswd`
# (repli sur Debian, où TigerVNC ne fournit plus vncpasswd).
VNC_AUTH="-SecurityTypes None"
if [ -n "${PENTBOX_VNC_PASSWORD:-}" ]; then
    mkdir -p "$HOME/.vnc"
    pwfile="$HOME/.vnc/passwd"
    if command -v vncpasswd >/dev/null 2>&1; then
        printf '%s' "$PENTBOX_VNC_PASSWORD" | vncpasswd -f > "$pwfile" 2>/dev/null
    elif command -v x11vnc >/dev/null 2>&1; then
        x11vnc -storepasswd "$PENTBOX_VNC_PASSWORD" "$pwfile" >/dev/null 2>&1
    fi
    if [ -s "$pwfile" ]; then
        chmod 600 "$pwfile"
        VNC_AUTH="-SecurityTypes VncAuth -PasswordFile $pwfile"
    fi
fi

# Serveur X virtuel + VNC : Xvnc en direct, localhost. $VNC_AUTH volontairement
# non quoté (2 mots-clés attendus, valeurs sans espace ni glob).
# shellcheck disable=SC2086
Xvnc ":$DISP" -geometry "$GEOMETRY" -depth 24 -rfbport "$VNC_PORT" \
     $VNC_AUTH -localhost -AlwaysShared >/tmp/pentbox-xvnc.log 2>&1 &

# Attendre que le display soit prêt.
i=0
while [ ! -S "/tmp/.X11-unix/X${DISP}" ] && [ "$i" -lt 20 ]; do
    sleep 0.5
    i=$((i + 1))
done

# Session de bureau XFCE sur ce display.
export DISPLAY=":$DISP"
if command -v dbus-launch >/dev/null 2>&1; then
    dbus-launch --exit-with-session startxfce4 >/tmp/pentbox-xfce.log 2>&1 &
else
    startxfce4 >/tmp/pentbox-xfce.log 2>&1 &
fi

# Fond d'écran pentbox — appliqué une fois la session XFCE/xfconf prête.
if [ -f /opt/pentbox/wallpaper.png ]; then
    (
        props=""
        for _ in 1 2 3 4 5 6 7 8; do
            sleep 2
            props=$(xfconf-query -c xfce4-desktop -l 2>/dev/null | grep 'last-image$')
            [ -n "$props" ] && break
        done
        for p in $props; do
            xfconf-query -c xfce4-desktop -p "$p" -s /opt/pentbox/wallpaper.png 2>/dev/null
        done
        for p in $(xfconf-query -c xfce4-desktop -l 2>/dev/null | grep 'image-style$'); do
            xfconf-query -c xfce4-desktop -p "$p" -s 5 2>/dev/null   # 5 = zoomed
        done

        # Thème sombre Materia (au runtime, en plus du XML baké).
        xfconf-query -c xsettings -p /Net/ThemeName -s Materia-dark 2>/dev/null \
            || xfconf-query -c xsettings -p /Net/ThemeName -n -t string -s Materia-dark 2>/dev/null
        xfconf-query -c xfwm4 -p /general/theme -s Materia-dark 2>/dev/null \
            || xfconf-query -c xfwm4 -p /general/theme -n -t string -s Materia-dark 2>/dev/null

        # Logo pentbox comme icône du menu Applications (à la place du logo XFCE).
        if [ -f /opt/pentbox/logo.png ]; then
            changed=0
            for pl in $(xfconf-query -c xfce4-panel -l 2>/dev/null | grep -E '/plugins/plugin-[0-9]+$'); do
                if [ "$(xfconf-query -c xfce4-panel -p "$pl" 2>/dev/null)" = "applicationsmenu" ]; then
                    xfconf-query -c xfce4-panel -p "$pl/button-icon" -n -t string -s /opt/pentbox/logo.png 2>/dev/null
                    xfconf-query -c xfce4-panel -p "$pl/show-button-title" -n -t bool -s false 2>/dev/null
                    changed=1
                fi
            done
            [ "$changed" = 1 ] && xfce4-panel --restart >/dev/null 2>&1 || true
        fi
    ) &
fi

# Localiser les fichiers web noVNC (chemin différent selon la distro :
# Debian = /usr/share/novnc, Arch = /usr/share/webapps/novnc).
NOVNC_WEB=/usr/share/novnc
for d in /usr/share/novnc /usr/share/webapps/novnc; do
    [ -f "$d/vnc.html" ] && NOVNC_WEB="$d" && break
done

# noVNC (websockify) → VNC, en écoute sur localhost uniquement.
exec websockify --web "$NOVNC_WEB" "127.0.0.1:$NOVNC_PORT" "localhost:$VNC_PORT"
