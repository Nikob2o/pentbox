#!/bin/sh
# pentbox — ouvre le shell de la mission, avec logging asciinema optionnel.
# Piloté par la variable PENTBOX_LOG (1 = enregistrer, sinon non). Copié dans
# chaque image (base-agnostique), appelé par `pentbox exec` en mode interactif.
set -u

# Terminal : si le terminfo du $TERM hérité de l'host manque dans l'image
# (ex. xterm-ghostty, foot, kitty…), l'édition de ligne (flèches / historique)
# casse. On retombe alors sur xterm-256color, universellement supporté.
if [ -z "${TERM:-}" ] || ! infocmp "$TERM" >/dev/null 2>&1; then
    TERM=xterm-256color
fi
export TERM

SHELL_BIN="$(command -v zsh 2>/dev/null || command -v bash 2>/dev/null || command -v sh)"

if [ "${PENTBOX_LOG:-1}" = "1" ] && command -v asciinema >/dev/null 2>&1; then
    LOGDIR="/workspace/logs"
    mkdir -p "$LOGDIR" 2>/dev/null || true
    OUT="$LOGDIR/$(date +%Y%m%d-%H%M%S).cast"
    printf 'pentbox: session enregistrée -> %s  (asciinema play <fichier> pour relire)\n' "$OUT"
    asciinema rec -q -c "$SHELL_BIN" "$OUT"
else
    exec "$SHELL_BIN"
fi
